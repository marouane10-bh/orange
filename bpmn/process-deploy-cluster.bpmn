    <bpmn:textAnnotation id="TextAnnotation_0rkkg58">
      <bpmn:text>Virtualization accepted</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1hkuvtq" sourceRef="car-ntss-validation" targetRef="TextAnnotation_0rkkg58" />
    <bpmn:textAnnotation id="TextAnnotation_0fur676">
      <bpmn:text>Create all server pool for each inventory group of workers/taint</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0jr7dkw">
      <bpmn:text>One virtual server per server pool of workers/taint
définition du port, du type (L4 TCP), application du profile</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1ysvqzz" sourceRef="TextAnnotation_0jr7dkw" targetRef="nsxt-vip-virtual-servers-creation-loop" />
    <bpmn:group id="nsxt-vip-cluster-creation" categoryValueRef="CategoryValue_13qd91b" />
    <bpmn:group id="rancher-cluster-creation" categoryValueRef="CategoryValue_102dbqe" />
    <bpmn:textAnnotation id="TextAnnotation_00dwoih">
      <bpmn:documentation>cxcxcxcxcxcxcxc</bpmn:documentation>
      <bpmn:text>Inputs :
- alias
- projectName
- isProd : true for a prod cluster
- taintSettings : westOnly / northWest / northWestSouth
- north : north node sizing and vIP if used
- west : west node sizing and vIP if used
- south south node sizing and vIP if used
- version : version of the cluster</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0k1smdt" sourceRef="StartEvent_1" targetRef="TextAnnotation_00dwoih" />
    <bpmn:textAnnotation id="TextAnnotation_0ntjeg8">
      <bpmn:text>Backups
Syntax of bucket name PROJECTNAME-(3P/PROD)

Automatisation de la création du bucket pour l'instant qui est fait à la main actuellement


API S3</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_08zrr3t" sourceRef="s3-bucket-creation" targetRef="TextAnnotation_0ntjeg8" />
    <bpmn:textAnnotation id="TextAnnotation_0angynk">
      <bpmn:text>RKE cluster template revision  witouht S3 creation</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1p7pd8k" sourceRef="rancher-revision-without-s3" targetRef="TextAnnotation_0angynk" />
    <bpmn:textAnnotation id="TextAnnotation_1mw65gd">
      <bpmn:text>RKE cluster template revision with S3 creation
/!\ Keep fake worker as we dont have S3 in lab</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0nizbco" sourceRef="TextAnnotation_1mw65gd" targetRef="rancher-revision-with-s3" />
    <bpmn:textAnnotation id="TextAnnotation_0fscnhd">
      <bpmn:text>Cluster deployment - Apply RKE template with S3</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0jvb554" sourceRef="TextAnnotation_0fscnhd" targetRef="cluster-updating-with-s3" />
    <bpmn:association id="Association_0h0gstn" sourceRef="TextAnnotation_0fur676" targetRef="nsxt-vip-server-pool-creation-loop" />
    <bpmn:textAnnotation id="TextAnnotation_0rezl5g">
      <bpmn:text>1 template for master node
1 template for worker/taint node</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0l8hxik" sourceRef="rancher-node-template-creation-loop" targetRef="TextAnnotation_0rezl5g" />
    <bpmn:group id="cluster-creation-validation" categoryValueRef="CategoryValue_08rwgfz" />
    <bpmn:textAnnotation id="TextAnnotation_0qhxb10">
      <bpmn:text>Create empty RKE template</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1jvqudy" sourceRef="rancher-create-empty-rke-template" targetRef="TextAnnotation_0qhxb10" />
    <bpmn:textAnnotation id="TextAnnotation_0y9usrk">
      <bpmn:text>Create empty cluster based on without S3 template revision</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1aemuux" sourceRef="rancher-empty-cluster" targetRef="TextAnnotation_0y9usrk" />
    <bpmn:textAnnotation id="TextAnnotation_17btehm">
      <bpmn:text>Need to add node pool master, taint for each</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1n74e3v" sourceRef="rancher-empty-cluster" targetRef="TextAnnotation_17btehm" />
    <bpmn:association id="Association_1p9jhpk" sourceRef="car-nsd-validatoin" targetRef="TextAnnotation_0q3rfvp" />
    <bpmn:textAnnotation id="TextAnnotation_0q3rfvp">
      <bpmn:text>Provide VIP</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1wpanf4">
      <bpmn:text>Loop to create inventory groups :
- URO_OKS_MASTER_projectName
- URO_OKS_WORKER_NORTH_projectName 
- URO_OKS_WORKER_WEST_projectName 
- URO_OKS_WORKER_SOUTH_projectName 
- URO_OKS_WORKER_projectName
- URO_OKS_projectName</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0dsfyo5" sourceRef="TextAnnotation_1wpanf4" targetRef="nsxt-create-inventory-groups" />
    <bpmn:textAnnotation id="TextAnnotation_159lv08">
      <bpmn:text>type : vsphere
mode : default</bpmn:text>
    </bpmn:textAnnotation>
