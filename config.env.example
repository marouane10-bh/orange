# ══════════════════════════════════════════════════════════════════════════════
# config.env.example
# Copy this file to config.env and fill in your values.
# config.env is git-ignored — never commit secrets.
# ══════════════════════════════════════════════════════════════════════════════

# ── Kubernetes namespaces ──────────────────────────────────────────────────────
APP_NAMESPACE=your-app-namespace          # namespace where your services run
MONITORING_NAMESPACE=monitoring           # namespace for observability tools

# ── Your application identity ──────────────────────────────────────────────────
APP_NAME=your-app-name                    # used as label in ServiceMonitor selector
APP_LABEL_KEY=app.kubernetes.io/part-of  # label key on your K8s Services
APP_LABEL_VALUE=your-project-name        # label value on your K8s Services

# ── Service names (must match your K8s Service names) ─────────────────────────
MAIN_SERVICE_NAME=your-main-service      # e.g. kogito-process-service
JOBS_SERVICE_NAME=your-jobs-service      # e.g. kogito-jobs-service
DATA_SERVICE_NAME=your-data-service      # e.g. kogito-data-index

# ── Metrics port (management port in Quarkus) ─────────────────────────────────
METRICS_PORT=9000                         # port where /q/metrics is exposed

# ── Prometheus configuration ──────────────────────────────────────────────────
PROMETHEUS_RETENTION=24h                  # how long to keep metrics (e.g. 24h, 7d)
PROMETHEUS_STORAGE=5Gi                    # persistent volume size for metrics
PROMETHEUS_HELM_VERSION=58.3.1           # pin the chart version
SCRAPE_INTERVAL=15s                       # how often Prometheus scrapes your services

# ── Grafana configuration ─────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-please  # CHANGE THIS
GRAFANA_FOLDER_NAME=My Project           # folder name in Grafana UI

# ── Jaeger configuration ──────────────────────────────────────────────────────
JAEGER_IMAGE_VERSION=1.57
JAEGER_MAX_TRACES=10000                  # max traces in memory (PoC only)

# ── Alert thresholds ──────────────────────────────────────────────────────────
ALERT_ERROR_RATE_THRESHOLD=5             # % error rate before firing alert
ALERT_KAFKA_LAG_THRESHOLD=1000           # messages behind before firing alert
ALERT_DB_CONNECTIONS_THRESHOLD=80       # % of max connections before firing
ALERT_MEMORY_THRESHOLD=90               # % JVM heap before firing alert

# ── Notification channels ─────────────────────────────────────────────────────
ALERT_EMAIL_TO=your-team@your-org.com
ALERT_EMAIL_FROM=alertmanager@your-org.com
ALERT_SMTP_HOST=smtp.your-org.com:587
ALERT_SMTP_USER=alertmanager
ALERT_SMTP_PASSWORD=change-me-please     # CHANGE THIS

ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
ALERT_SLACK_CHANNEL=#your-alerts-channel

# ── Runbook base URL (update after pushing to GitHub) ─────────────────────────
RUNBOOK_BASE_URL=https://github.com/your-org/your-repo/blob/main/runbooks

# ── Quarkus application settings (for application.properties template) ────────
QUARKUS_APP_NAME=your-service-name       # appears as service name in Jaeger
OTEL_SAMPLING_RATE=always_on            # always_on for PoC, parentbased_traceidratio for prod
